# local = bundled frontend demo data only
# api   = Laravel backend at VITE_API_BASE_URL
VITE_DATA_MODE=api
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1
VITE_ADMIN_REFERENCE_HEADER=X-ORDERra-Admin-Key
VITE_ADMIN_REFERENCE_KEY=orderra-local-admin-demo-key
VITE_PAYMENT_SIMULATION_OUTCOME=success

# Match Laravel FRONTEND_URL so printed QR cards resolve to this dev host.
# VITE_DEV_HOST is informational only; Vite reads host from npm script defaults.
