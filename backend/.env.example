APP_NAME=ORDERra
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_TIMEZONE=America/New_York

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite
DB_FOREIGN_KEYS=true

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="demo@orderra.test"
MAIL_FROM_NAME="${APP_NAME}"

FRONTEND_URL=http://localhost:5173

ORDERRA_CURRENCY=USD
ORDERRA_ORDER_CODE_PREFIX=ORD

ADMIN_REFERENCE_GUARD_ENABLED=true
ADMIN_REFERENCE_HEADER=X-ORDERra-Admin-Key
ADMIN_REFERENCE_TOKEN=change-this-demo-admin-key
ADMIN_REFERENCE_READONLY=false
ADMIN_REFERENCE_RATE_LIMIT=60
ADMIN_LOGIN_RATE_LIMIT=12

PAYMENTS_DEMO_MODE=true
PAYMENTS_BLOCK_LIVE_EXECUTION=true
PAYMENTS_ALLOW_WEBHOOK_SIMULATION=true
PAYMENTS_DEFAULT_COUNTRY=US
PAYMENTS_DEFAULT_CURRENCY=USD
PAYMENTS_SAFE_PROVIDER_MODES=demo,sandbox,test
PAYMENTS_DEMO_PROVIDER_DRIVERS=demo

VITE_APP_NAME="${APP_NAME}"

PUBLIC_API_RATE_LIMIT=120
PAYMENT_SIMULATION_RATE_LIMIT=20
WEBHOOK_SIMULATION_RATE_LIMIT=15

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ------------------------------------------------------------------------------------
# Local portfolio demos (migrate --seed): run `composer install` after adding laravel/sanctum,
# then `php artisan migrate --seed`.
# Sanctum staff users:
# - admin@orderra.test / password (role: admin)
# - staff@orderra.test / password (role: staff)
# The reference key (ADMIN_REFERENCE_*) remains a fallback when no Bearer token is sent.

